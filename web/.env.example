# ============================================
# LinZhi Web Environment Variables - REFERENCE ONLY
# ============================================
# 
# ⚠️  DO NOT USE THIS FILE DIRECTLY
# 
# All environment variables are managed in:
#   /srv/linzhi/ecosystem.config.js
# 
# This project uses ONLY PM2 production mode.
# There is NO separate development mode.
# 
# Development workflow:
#   1. Edit code
#   2. npm run build
#   3. pm2 restart linzhi-web
# ============================================

# API Proxy Target (for Next.js rewrites)
API_PROXY_TARGET=http://127.0.0.1:8000

# NextAuth Configuration
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=your-secret-key-here

# Database Connection (for NextAuth PostgreSQL adapter)
DATABASE_URL=postgres://user:password@127.0.0.1:5432/linzhi?sslmode=disable

# P2: Workspace selector (dev/preview)
NEXT_PUBLIC_WORKSPACE_SELECTOR_ENABLED=0
